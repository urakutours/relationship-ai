// 人間関係ナビゲーションアプリのデータベーススキーマ

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 人物（パーソナルCRM）
model Person {
  id             String   @id @default(cuid())
  nickname       String
  relationship   String   // 上司/部下/配偶者/クライアント/友人
  birthDate      String?  // YYYY-MM-DD形式（任意）
  birthYear      Int?     // 生まれた年（任意）
  gender         String?  // 男性/女性/その他
  bloodType      String?  // A/B/O/AB
  birthCountry   String?  // 出身国
  birthOrder     String?  // 長子/中間/末子/一人っ子/不明
  personalContext String?  // 家族構成・パートナーの有無・生活環境などの自由記述
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // AI生成ノート
  quickNote           String?    // Haiku生成のサマリーノート
  deepNote            String?    // Sonnet生成の詳細ノート
  compatibilityScore  Int?       // 自分との相性スコア（1〜100）
  quickNoteUpdatedAt  DateTime?
  deepNoteUpdatedAt   DateTime?

  // ラベル・並び替え
  labels      PersonLabel[]
  sortOrder   Int?           // 並び替え順序（nullの場合はid順）

  // 相談履歴
  consultations  ConsultationLog[]

  // 観察メモ（複数追加可）
  observations   Observation[]
}

// 相談履歴
model ConsultationLog {
  id            String   @id @default(cuid())
  personId      String
  person        Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  consultType   String   // "standard" / "deep"
  context       String   // 相談内容
  result        String   // AI回答
  createdAt     DateTime @default(now())
}

// 自分のプロフィール（常に1件のみ、id=1で固定）
model UserProfile {
  id            Int       @id @default(1)
  nickname      String    @default("自分")
  birthDate     String?   // YYYY-MM-DD形式（任意）
  birthYear     Int?      // 生まれた年（任意）
  gender        String?   // male / female / other
  bloodType     String?   // A / B / O / AB
  birthOrder    String?   // first / middle / last / only
  birthCountry  String?   @default("JP")
  mbti          String?   // 例: "INTJ"
  memoTags      String?   // JSON文字列として保存（自分の特性メモ配列）
  // AI生成ノート
  quickNote          String?
  deepNote           String?
  quickNoteUpdatedAt DateTime?
  deepNoteUpdatedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 観察メモ
model Observation {
  id        String   @id @default(cuid())
  content   String
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ラベル
model Label {
  id        Int           @id @default(autoincrement())
  name      String        // ラベル名（例：「重要」「要注意」「VIP」）
  color     String        @default("#7ec8c0") // カラーコード
  createdAt DateTime      @default(now())
  persons   PersonLabel[]
}

// 人物×ラベル中間テーブル
model PersonLabel {
  personId  String
  labelId   Int
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  label     Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([personId, labelId])
}
